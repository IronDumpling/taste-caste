{
  "version": 1,
  "dimensions": {
    "popularity": {
      "description": "0-100, 越低越小众",
      "sources": [
        { "id": "igdb", "weight": 1.0, "enabled": true, "field": "rating_count", "normalize": "log_100" },
        { "id": "bangumi", "weight": 0.8, "enabled": false, "field": "rating_count", "normalize": "log_100" }
      ]
    },
    "critic": {
      "description": "0-100, 越高越硬核/艺术",
      "sources": [
        { "id": "igdb", "weight": 0.5, "enabled": true, "field": "aggregated_rating", "scale": [0, 100] },
        { "id": "opencritic", "weight": 1.0, "enabled": true, "field": "topCriticScore", "scale": [0, 100] },
        { "id": "bangumi", "weight": 0.7, "enabled": false, "field": "rating", "scale": [0, 10], "scaleTo100": true }
      ]
    }
  },
  "casteBounds": [
    { "id": "brahmin", "popularity": [0, 40], "critic": [85, 100] },
    { "id": "kshatriya", "popularity": [40, 70], "critic": [80, 100] },
    { "id": "vaishya", "popularity": [70, 100], "critic": [60, 85] },
    { "id": "shudra", "popularity": [80, 100], "critic": [0, 60] }
  ],
  "answerBlendAlpha": 0.4,
  "whenSourceMissing": "renormalize",
  "fallback": { "popularity": 50, "critic": 50 },
  "selectionAggregation": "mean"
}
